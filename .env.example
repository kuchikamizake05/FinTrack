# Browser-safe credentials from Supabase Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only: used by app/api/trades/[tradeId]/review; never prefix with NEXT_PUBLIC_
N8N_TRADE_REVIEW_WEBHOOK_URL=https://your-n8n.example/webhook/fintrack-trade-review
N8N_TRADE_REVIEW_SHARED_SECRET=replace-with-a-long-random-secret
